{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@ode/config": ["packages/config/index.ts"],
      "@ode/config/*": ["packages/config/*"],
      "@ode/core": ["packages/core/index.ts"],
      "@ode/core/*": ["packages/core/*"],
      "@ode/utils": ["packages/utils/index.ts"],
      "@ode/utils/*": ["packages/utils/*"],
      "@ode/ims": ["packages/ims/index.ts"],
      "@ode/ims/*": ["packages/ims/*"],
      "@ode/agents": ["packages/agents/index.ts"],
      "@ode/agents/*": ["packages/agents/*"]
    },
    // Environment setup & latest features
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,

    // Bundler mode
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    // Best practices
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,

    // Some stricter flags (disabled by default)
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false
  }
}
